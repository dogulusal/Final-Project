# ============================================
# AI Haber Ajansı — Ortam Değişkenleri
# ============================================
# Bu dosyayı .env olarak kopyala ve değerleri doldur:
#   cp .env.example .env
# ============================================

# --- Ortam ---
NODE_ENV=development
PORT=3000

# --- Veritabanı (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=news_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# --- LLM Provider ---
# Desteklenen: openai | gemini | anthropic | ollama
LLM_PROVIDER=ollama
LLM_API_KEY=your_api_key_here
LLM_MODEL_NAME=your_model_name_here
LLM_BASE_URL=http://localhost:11434

# --- Fine-tuned Model (opsiyonel) ---
LLM_FINE_TUNED_MODEL=
LLM_FALLBACK_PROVIDER=ollama

# --- n8n ---
N8N_USER=admin
N8N_PASSWORD=your_n8n_password_here
N8N_HOST=localhost

# --- Sosyal Medya API (opsiyonel, mock mode varsayılan) ---
SOCIAL_MEDIA_MODE=mock
# Twitter/X
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
# Instagram (Graph API)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
# LinkedIn
LINKEDIN_ACCESS_TOKEN=

# --- ML Model ---
ML_CONFIDENCE_THRESHOLD=0.60
ML_RETRAIN_ON_DRIFT=false

# --- Genel ---
LOG_LEVEL=info
CACHE_TTL_SECONDS=300
DAILY_NEWS_LIMIT=100
